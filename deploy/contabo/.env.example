# Copy this file to deploy/contabo/.env on the VPS and replace every value.

# Domain that will open the POS. Example: pos.dlightgiftshop.com
APP_DOMAIN=pos.example.com

# PostgreSQL application password. Use a long random value.
POSTGRES_PASSWORD=replace_with_long_random_database_password

# JWT secrets. Use two different long random values.
JWT_SECRET=replace_with_64_plus_random_hex_characters
JWT_REFRESH_SECRET=replace_with_different_64_plus_random_hex_characters

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
